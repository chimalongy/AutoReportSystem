@* ══════════════ CONFIRM MODAL ══════════════ *@
<div id="confirmModal"
     class="fixed inset-0 z-50 bg-black/40 backdrop-blur-sm items-center justify-center px-4">
    <div id="confirmBox"
         class="bg-surface-card border border-border rounded-2xl shadow-xl w-full max-w-sm px-6 py-6">
        <div id="confirmIcon" class="w-10 h-10 rounded-full flex items-center justify-center mx-auto mb-4"></div>
        <h3 id="confirmTitle" class="text-text-primary font-semibold text-base text-center mb-1"></h3>
        <p id="confirmMessage" class="text-text-muted text-sm text-center mb-5"></p>
        <div class="flex gap-3">
            <button onclick="closeConfirm()"
                    class="flex-1 py-2 text-sm text-text-secondary border border-border rounded-xl hover:bg-surface transition-colors">
                Cancel
            </button>
            <button id="confirmActionBtn"
                    class="flex-1 py-2 text-sm font-medium text-white rounded-xl transition-colors">
                Confirm
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let allDbConfigs = [];
    let pendingAction = null;

    // ── Load database configs on page load ───────────────────────────────────
    async function loadDbConfigs() {
        try {
            const res = await fetch('/Dashboard/Databases/GetAll');
            if (!res.ok) throw new Error('Failed to fetch');
            allDbConfigs = await res.json();
            renderTable(allDbConfigs);
        } catch (err) {
            document.getElementById('dbTableBody').innerHTML = `
                <tr>
                    <td colspan="7" class="text-center py-12 text-text-muted text-xs">
                        Failed to load database configurations. Please refresh the page.
                    </td>
                </tr>`;
        }
    }

    // ── Render table ─────────────────────────────────────────────────────────
    function renderTable(configs) {
        const tbody = document.getElementById('dbTableBody');
        const countEl = document.getElementById('dbCount');

        countEl.textContent = `${configs.length} configuration${configs.length !== 1 ? 's' : ''}`;

        if (configs.length === 0) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="7" class="text-center py-12 text-text-muted text-xs">
                        No database configurations found. Add one to get started.
                    </td>
                </tr>`;
            return;
        }

        tbody.innerHTML = configs.map(c => {
            const isInactive = (c.status || '').toLowerCase() === 'inactive';
            const typeIcon = c.databaseType === 'Oracle'
                ? `<span class="text-xs px-2 py-0.5 rounded-full border bg-orange-50 text-orange-600 border-orange-100">Oracle</span>`
                : `<span class="text-xs px-2 py-0.5 rounded-full border bg-blue-50 text-blue-600 border-blue-100">PostgreSQL</span>`;

            return `
            <tr class="db-row border-b border-border last:border-0" id="row-${c.id}">
                <td class="px-5 py-3.5">
                    <div class="flex items-center gap-2.5">
                        <div class="w-8 h-8 rounded-lg bg-surface border border-border
                                    flex items-center justify-center flex-shrink-0">
                            <svg class="w-4 h-4 text-text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <ellipse cx="12" cy="5" rx="9" ry="3"/>
                                <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
                                <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
                            </svg>
                        </div>
                        <span class="text-text-primary font-medium">${escHtml(c.databaseName)}</span>
                    </div>
                </td>
                <td class="px-5 py-3.5 hidden md:table-cell">${typeIcon}</td>
                <td class="px-5 py-3.5 text-text-secondary hidden sm:table-cell">${escHtml(c.host)}</td>
                <td class="px-5 py-3.5 text-text-secondary">${c.port}</td>
                <td class="px-5 py-3.5 text-text-secondary hidden lg:table-cell">${escHtml(c.username)}</td>
                <td class="px-5 py-3.5">
                    <span class="text-xs px-2.5 py-0.5 rounded-full font-medium
                        ${isInactive ? 'badge-inactive' : 'badge-active'}">
                        ${isInactive ? 'Inactive' : 'Active'}
                    </span>
                </td>
                <td class="px-5 py-3.5 text-right">
                    <div class="flex items-center justify-end gap-1">
                        <button onclick="testExistingConnection(${c.id})"
                                title="Test connection"
                                class="text-xs px-2 py-1.5 rounded-lg border border-blue-200
                                       text-blue-600 hover:bg-blue-50 transition-colors flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M5 12h14M12 5l7 7-7 7"/>
                            </svg>
                            Test
                        </button>
                        <button onclick="openEditModal(${c.id})"
                                title="Edit configuration"
                                class="text-xs px-2.5 py-1.5 rounded-lg border border-border
                                       text-text-secondary hover:border-blue-300 hover:text-blue-600
                                       hover:bg-blue-50 transition-colors">
                            Edit
                        </button>
                        <button onclick="confirmToggleStatus(${c.id}, ${isInactive})"
                                title="${isInactive ? 'Activate' : 'Deactivate'}"
                                class="text-xs px-2.5 py-1.5 rounded-lg border transition-colors
                                    ${isInactive
                                        ? 'border-blue-200 text-blue-600 hover:bg-blue-50'
                                        : 'border-border text-text-secondary hover:border-amber-300 hover:text-amber-600 hover:bg-amber-50'}">
                            ${isInactive ? 'Activate' : 'Deactivate'}
                        </button>
                        <button onclick="confirmDelete(${c.id}, '${escHtml(c.databaseName)}')"
                                title="Delete configuration"
                                class="text-xs px-2.5 py-1.5 rounded-lg border border-border
                                       text-text-secondary hover:border-red-300 hover:text-red-600
                                       hover:bg-red-50 transition-colors">
                            Delete
                        </button>
                    </div>
                </td>
            </tr>`;
        }).join('');
    }

    // ── Escape HTML helper ───────────────────────────────────────────────────
    function escHtml(str) {
        return String(str)
            .replace(/&/g,'&amp;').replace(/</g,'&lt;')
            .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── Confirm modal helpers ────────────────────────────────────────────────
    function openConfirm({ icon, iconBg, title, message, btnColor, action }) {
        document.getElementById('confirmIcon').className =
            `w-10 h-10 rounded-full flex items-center justify-center mx-auto mb-4 ${iconBg}`;
        document.getElementById('confirmIcon').innerHTML = icon;
        document.getElementById('confirmTitle').textContent   = title;
        document.getElementById('confirmMessage').textContent = message;

        const btn = document.getElementById('confirmActionBtn');
        btn.className = `flex-1 py-2 text-sm font-medium text-white rounded-xl transition-colors ${btnColor}`;
        pendingAction = action;
        btn.onclick = () => { pendingAction(); };

        document.getElementById('confirmModal').classList.add('open');
    }

    function closeConfirm() {
        document.getElementById('confirmModal').classList.remove('open');
        pendingAction = null;
    }

    // ── Delete ───────────────────────────────────────────────────────────────
    function confirmDelete(dbId, dbName) {
        openConfirm({
            icon: `<svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                       <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                       <path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/>
                   </svg>`,
            iconBg:   'bg-red-50',
            title:    'Delete Configuration',
            message:  `Are you sure you want to permanently delete the configuration for '${dbName}'? This action cannot be undone.`,
            btnColor: 'bg-red-500 hover:bg-red-600',
            action:   () => deleteDbConfig(dbId)
        });
    }

    async function deleteDbConfig(dbId) {
        closeConfirm();
        try {
            const res = await fetch(`/Dashboard/Databases/Delete/${dbId}`, { method: 'POST' });
            if (!res.ok) throw new Error();
            document.getElementById(`row-${dbId}`)?.remove();
            allDbConfigs = allDbConfigs.filter(c => c.id !== dbId);
            document.getElementById('dbCount').textContent =
                `${allDbConfigs.length} configuration${allDbConfigs.length !== 1 ? 's' : ''}`;
            showAlert('Database configuration deleted successfully.', 'success');
        } catch {
            showAlert('Failed to delete configuration. Please try again.', 'error');
        }
    }

    // ── Toggle Status (Activate/Deactivate) ──────────────────────────────────
    function confirmToggleStatus(dbId, isCurrentlyInactive) {
        const action = isCurrentlyInactive ? 'activate' : 'deactivate';
        const config = allDbConfigs.find(c => c.id === dbId);
        const dbName = config ? config.databaseName : 'this configuration';

        openConfirm({
            icon: `<svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                       <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
                       <line x1="12" y1="16" x2="12.01" y2="16"/>
                   </svg>`,
            iconBg:   'bg-amber-50',
            title:    `${isCurrentlyInactive ? 'Activate' : 'Deactivate'} Configuration`,
            message:  `Are you sure you want to ${action} the configuration for '${dbName}'?`,
            btnColor: 'bg-amber-500 hover:bg-amber-600',
            action:   () => toggleDbStatus(dbId, isCurrentlyInactive)
        });
    }

    async function toggleDbStatus(dbId, isCurrentlyInactive) {
        closeConfirm();
        const newStatus = isCurrentlyInactive ? 'active' : 'inactive';
        try {
            const res = await fetch(`/Dashboard/Databases/UpdateStatus/${dbId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: newStatus })
            });
            if (!res.ok) throw new Error();
            const config = allDbConfigs.find(c => c.id === dbId);
            if (config) config.status = newStatus;
            renderTable(allDbConfigs);
            showAlert(`Configuration ${newStatus === 'active' ? 'activated' : 'deactivated'} successfully.`, 'success');
        } catch {
            showAlert('Failed to update configuration status. Please try again.', 'error');
        }
    }

    // ── Test Existing Connection ─────────────────────────────────────────────
    async function testExistingConnection(dbId) {
        const config = allDbConfigs.find(c => c.id === dbId);
        const dbName = config ? config.databaseName : 'database';

        showAlert(`Testing connection to '${dbName}'...`, 'success');

        try {
            const res = await fetch(`/Dashboard/Databases/TestExisting/${dbId}`, { method: 'POST' });
            const data = await res.json();
            if (res.ok) {
                showAlert(`Connection to '${dbName}' successful! Database is reachable.`, 'success');
            } else {
                showAlert(`Connection to '${dbName}' failed: ${data.message || 'Unknown error'}`, 'error');
            }
        } catch {
            showAlert(`Failed to test connection to '${dbName}'. Please try again.`, 'error');
        }
    }

    // ── Test Connection from Modal (Add) ────────────────────────────────────
    async function testConnectionFromModal() {
        const databaseType = document.getElementById('newDbType').value;
        const host = document.getElementById('newDbHost').value.trim();
        const port = parseInt(document.getElementById('newDbPort').value);
        const databaseName = document.getElementById('newDbName').value.trim();
        const username = document.getElementById('newDbUsername').value.trim();
        const password = document.getElementById('newDbPassword').value;

        if (!host || !databaseName || !username || !password || !port) {
            showTestResult('testResultArea', 'Please fill in all required fields before testing.', false);
            return;
        }

        setTestLoading(true);
        try {
            const res = await fetch('/Dashboard/Databases/TestConnection', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ databaseType, host, port, databaseName, username, password })
            });
            const data = await res.json();
            if (res.ok) {
                showTestResult('testResultArea', data.message || 'Connection successful!', true);
            } else {
                showTestResult('testResultArea', data.message || 'Connection failed.', false);
            }
        } catch {
            showTestResult('testResultArea', 'Failed to test connection. Please try again.', false);
        } finally {
            setTestLoading(false);
        }
    }

    // ── Test Connection from Edit Modal ──────────────────────────────────────
    async function testConnectionFromEditModal() {
        const databaseType = document.getElementById('editDbType').value;
        const host = document.getElementById('editDbHost').value.trim();
        const port = parseInt(document.getElementById('editDbPort').value);
        const databaseName = document.getElementById('editDbName').value.trim();
        const username = document.getElementById('editDbUsername').value.trim();
        const password = document.getElementById('editDbPassword').value;

        if (!host || !databaseName || !username || !port) {
            showTestResult('editTestResultArea', 'Host, port, database name, and username are required.', false);
            return;
        }

        // If password is blank, test using the existing saved connection
        if (!password) {
            const id = parseInt(document.getElementById('editDbId').value);
            setEditTestLoading(true);
            try {
                const res = await fetch(`/Dashboard/Databases/TestExisting/${id}`, { method: 'POST' });
                const data = await res.json();
                if (res.ok) {
                    showTestResult('editTestResultArea', data.message || 'Connection successful!', true);
                } else {
                    showTestResult('editTestResultArea', data.message || 'Connection failed.', false);
                }
            } catch {
                showTestResult('editTestResultArea', 'Failed to test connection. Please try again.', false);
            } finally {
                setEditTestLoading(false);
            }
            return;
        }

        setEditTestLoading(true);
        try {
            const res = await fetch('/Dashboard/Databases/TestConnection', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ databaseType, host, port, databaseName, username, password })
            });
            const data = await res.json();
            if (res.ok) {
                showTestResult('editTestResultArea', data.message || 'Connection successful!', true);
            } else {
                showTestResult('editTestResultArea', data.message || 'Connection failed.', false);
            }
        } catch {
            showTestResult('editTestResultArea', 'Failed to test connection. Please try again.', false);
        } finally {
            setEditTestLoading(false);
        }
    }

    function showTestResult(areaId, message, isSuccess) {
        const el = document.getElementById(areaId);
        el.className = `rounded-xl px-4 py-3 text-sm ${isSuccess ? 'test-result-success' : 'test-result-error'}`;
        el.innerHTML = `
            <div class="flex items-center gap-2">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    ${isSuccess
                        ? '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>'
                        : '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>'}
                </svg>
                ${escHtml(message)}
            </div>`;
        el.classList.remove('hidden');
    }

    function hideTestResult(areaId) {
        document.getElementById(areaId).classList.add('hidden');
    }

    function setTestLoading(loading) {
        const btn = document.getElementById('testConnectionBtn');
        const spinner = document.getElementById('testBtnSpinner');
        const text = document.getElementById('testBtnText');
        btn.disabled = loading;
        spinner.classList.toggle('hidden', !loading);
        text.textContent = loading ? 'Testing...' : 'Test Connection';
    }

    function setEditTestLoading(loading) {
        const btn = document.getElementById('editTestConnectionBtn');
        const spinner = document.getElementById('editTestBtnSpinner');
        const text = document.getElementById('editTestBtnText');
        btn.disabled = loading;
        spinner.classList.toggle('hidden', !loading);
        text.textContent = loading ? 'Testing...' : 'Test Connection';
    }

    // ── Add Database Modal ───────────────────────────────────────────────────
    function openAddModal() {
        document.getElementById('newDbType').value = 'PostgreSQL';
        document.getElementById('newDbHost').value = '';
        document.getElementById('newDbPort').value = '5432';
        document.getElementById('newDbName').value = '';
        document.getElementById('newDbUsername').value = '';
        document.getElementById('newDbPassword').value = '';
        document.getElementById('modalAlert').classList.add('hidden');
        hideTestResult('testResultArea');
        document.getElementById('dbModal').classList.add('open');
        document.getElementById('newDbHost').focus();
    }

    function closeAddModal() {
        document.getElementById('dbModal').classList.remove('open');
    }

    async function saveDbConfig() {
        const databaseType = document.getElementById('newDbType').value;
        const host = document.getElementById('newDbHost').value.trim();
        const port = parseInt(document.getElementById('newDbPort').value);
        const databaseName = document.getElementById('newDbName').value.trim();
        const username = document.getElementById('newDbUsername').value.trim();
        const password = document.getElementById('newDbPassword').value;

        if (!host || !databaseName || !username || !password) {
            showModalAlert('Please fill in all required fields.', 'error');
            return;
        }
        if (!port || port <= 0 || port > 65535) {
            showModalAlert('Port must be between 1 and 65535.', 'error');
            return;
        }

        const btn = document.getElementById('saveDbBtn');
        const spinner = document.getElementById('saveBtnSpinner');
        const btnText = document.getElementById('saveBtnText');
        btn.disabled = true;
        spinner.classList.remove('hidden');
        btnText.textContent = 'Saving...';

        try {
            const res = await fetch('/Dashboard/Databases/Create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ databaseType, host, port, databaseName, username, password })
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.message || 'Failed to save configuration');

            allDbConfigs.unshift(data);
            renderTable(allDbConfigs);
            closeAddModal();
            showAlert(`Database configuration for '${databaseName}' created successfully.`, 'success');
        } catch (err) {
            showModalAlert(err.message || 'Failed to save configuration. Please try again.', 'error');
        } finally {
            btn.disabled = false;
            spinner.classList.add('hidden');
            btnText.textContent = 'Save Configuration';
        }
    }

    // ── Edit Database Modal ──────────────────────────────────────────────────
    function openEditModal(dbId) {
        const config = allDbConfigs.find(c => c.id === dbId);
        if (!config) return;

        document.getElementById('editDbId').value = dbId;
        document.getElementById('editDbType').value = config.databaseType || 'PostgreSQL';
        document.getElementById('editDbHost').value = config.host || '';
        document.getElementById('editDbPort').value = config.port || '';
        document.getElementById('editDbName').value = config.databaseName || '';
        document.getElementById('editDbUsername').value = config.username || '';
        document.getElementById('editDbPassword').value = '';
        document.getElementById('editModalAlert').classList.add('hidden');
        hideTestResult('editTestResultArea');
        document.getElementById('editDbModal').classList.add('open');
    }

    function closeEditModal() {
        document.getElementById('editDbModal').classList.remove('open');
    }

    async function updateDbConfig() {
        const id = parseInt(document.getElementById('editDbId').value);
        const databaseType = document.getElementById('editDbType').value;
        const host = document.getElementById('editDbHost').value.trim();
        const port = parseInt(document.getElementById('editDbPort').value);
        const databaseName = document.getElementById('editDbName').value.trim();
        const username = document.getElementById('editDbUsername').value.trim();
        const password = document.getElementById('editDbPassword').value;

        if (!host || !databaseName || !username) {
            showEditModalAlert('Host, database name, and username are required.', 'error');
            return;
        }
        if (!port || port <= 0 || port > 65535) {
            showEditModalAlert('Port must be between 1 and 65535.', 'error');
            return;
        }

        const btn = document.getElementById('updateDbBtn');
        const spinner = document.getElementById('updateBtnSpinner');
        const btnText = document.getElementById('updateBtnText');
        btn.disabled = true;
        spinner.classList.remove('hidden');
        btnText.textContent = 'Updating...';

        const payload = { id, databaseType, host, port, databaseName, username };
        if (password) payload.password = password;

        try {
            const res = await fetch(`/Dashboard/Databases/Update/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.message || 'Failed to update configuration');

            const idx = allDbConfigs.findIndex(c => c.id === id);
            if (idx >= 0) allDbConfigs[idx] = data;
            renderTable(allDbConfigs);
            closeEditModal();
            showAlert('Database configuration updated successfully.', 'success');
        } catch (err) {
            showEditModalAlert(err.message || 'Failed to update configuration. Please try again.', 'error');
        } finally {
            btn.disabled = false;
            spinner.classList.add('hidden');
            btnText.textContent = 'Update Configuration';
        }
    }

    // ── Alert helpers ────────────────────────────────────────────────────────
    function showAlert(message, type) {
        const el = document.getElementById('alertArea');
        const isSuccess = type === 'success';
        el.className = `mb-4 px-4 py-3 rounded-xl text-sm border flex items-center gap-2
            ${isSuccess
                ? 'bg-green-50 text-green-700 border-green-200'
                : 'bg-red-50 text-red-700 border-red-200'}`;
        el.innerHTML = `
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                ${isSuccess
                    ? '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>'
                    : '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>'}
            </svg>
            ${escHtml(message)}`;
        el.classList.remove('hidden');
        setTimeout(() => el.classList.add('hidden'), 5000);
    }

    function showModalAlert(message, type) {
        const el = document.getElementById('modalAlert');
        el.className = `mb-1 px-3 py-2 rounded-xl text-xs border
            ${type === 'error' ? 'bg-red-50 text-red-700 border-red-200' : 'bg-green-50 text-green-700 border-green-200'}`;
        el.textContent = message;
        el.classList.remove('hidden');
    }

    function showEditModalAlert(message, type) {
        const el = document.getElementById('editModalAlert');
        el.className = `mb-1 px-3 py-2 rounded-xl text-xs border
            ${type === 'error' ? 'bg-red-50 text-red-700 border-red-200' : 'bg-green-50 text-green-700 border-green-200'}`;
        el.textContent = message;
        el.classList.remove('hidden');
    }

    // Close modals on backdrop click
    document.getElementById('dbModal').addEventListener('click', function(e) {
        if (e.target === this) closeAddModal();
    });
    document.getElementById('editDbModal').addEventListener('click', function(e) {
        if (e.target === this) closeEditModal();
    });
    document.getElementById('confirmModal').addEventListener('click', function(e) {
        if (e.target === this) closeConfirm();
    });

    // Enter key handlers
    ['newDbHost','newDbPort','newDbName','newDbUsername','newDbPassword'].forEach(id => {
        document.getElementById(id)?.addEventListener('keydown', e => {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); saveDbConfig(); }
        });
    });
    ['editDbHost','editDbPort','editDbName','editDbUsername','editDbPassword'].forEach(id => {
        document.getElementById(id)?.addEventListener('keydown', e => {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); updateDbConfig(); }
        });
    });

    // Set default port based on database type
    document.getElementById('newDbType').addEventListener('change', function() {
        const portField = document.getElementById('newDbPort');
        if (!portField.value) {
            portField.value = this.value === 'Oracle' ? '1521' : '5432';
        }
    });

    // Load on page ready
    loadDbConfigs();
</script>
}
