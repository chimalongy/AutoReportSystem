@{
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    if (!role.Equals("Super Admin", StringComparison.OrdinalIgnoreCase) &&
        !role.Equals("Admin", StringComparison.OrdinalIgnoreCase))
    {
        Context.Response.Redirect("/Dashboard/Index");
        return;
    }
}

@{
    ViewData["Title"] = "Databases";
    ViewData["ActivePage"] = "Databases";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @@keyframes fadeIn {
        from { opacity: 0; }
        to   { opacity: 1; }
    }
    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(32px) scale(0.98); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .fade-up { opacity: 0; animation: fadeUp 0.45s ease forwards; }
    .fade-up-1 { animation-delay: 0.05s; }
    .fade-up-2 { animation-delay: 0.15s; }
    .fade-up-3 { animation-delay: 0.25s; }

    #dbModal, #editDbModal, #testModal {
        display: none;
        animation: fadeIn 0.2s ease forwards;
    }
    #dbModal.open, #editDbModal.open, #testModal.open { display: flex; }
    #modalBox, #editModalBox, #testModalBox {
        animation: slideUp 0.28s cubic-bezier(0.34, 1.4, 0.64, 1) forwards;
    }

    .db-row { transition: background 0.15s ease; }
    .db-row:hover { background: var(--color-surface, #f8fafc); }

    .badge-active   { background: #dcfce7; color: #16a34a; border: 1px solid #bbf7d0; }
    .badge-inactive { background: #fee2e2; color: #dc2626; border: 1px solid #fecaca; }

    @@keyframes spin { to { transform: rotate(360deg); } }
    .spinner { animation: spin 0.7s linear infinite; }

    #confirmModal {
        display: none;
        animation: fadeIn 0.15s ease forwards;
    }
    #confirmModal.open { display: flex; }
    #confirmBox {
        animation: slideUp 0.22s cubic-bezier(0.34, 1.4, 0.64, 1) forwards;
    }

    .test-result-success {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #16a34a;
    }
    .test-result-error {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
    }
</style>

@* ── Page header ── *@
<div class="flex items-center justify-between mb-6 fade-up fade-up-1">
    <div>
        <h1 class="text-text-primary text-2xl font-semibold">Databases</h1>
        <p class="text-text-muted text-sm mt-0.5">Configure and manage external database connections.</p>
    </div>
    <button onclick="openAddModal()"
            class="flex items-center gap-2 px-4 py-2.5 bg-blue-600 hover:bg-blue-700
                   text-white text-sm font-medium rounded-xl transition-colors shadow-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path d="M12 5v14M5 12h14"/>
        </svg>
        Add Database
    </button>
</div>

@* ── Alert area ── *@
<div id="alertArea" class="hidden mb-4"></div>



@* ── Databases table card ── *@
<div class="bg-surface-card border border-border rounded-2xl shadow-sm overflow-hidden fade-up fade-up-3">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-border bg-surface">
                    <th class="text-left text-xs font-semibold text-text-muted px-5 py-3 uppercase tracking-wide">Database</th>
                    <th class="text-left text-xs font-semibold text-text-muted px-5 py-3 uppercase tracking-wide hidden md:table-cell">Type</th>
                    <th class="text-left text-xs font-semibold text-text-muted px-5 py-3 uppercase tracking-wide hidden sm:table-cell">Host</th>
                    <th class="text-left text-xs font-semibold text-text-muted px-5 py-3 uppercase tracking-wide">Port</th>
                    <th class="text-left text-xs font-semibold text-text-muted px-5 py-3 uppercase tracking-wide hidden lg:table-cell">Username</th>
                    <th class="text-left text-xs font-semibold text-text-muted px-5 py-3 uppercase tracking-wide">Status</th>
                    <th class="text-right text-xs font-semibold text-text-muted px-5 py-3 uppercase tracking-wide">Actions</th>
                </tr>
            </thead>
            <tbody id="dbTableBody">
                <tr>
                    <td colspan="7" class="text-center py-12 text-text-muted">
                        <svg class="w-5 h-5 mx-auto mb-2 spinner text-blue-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
                        </svg>
                        <span class="text-xs">Loading database configurations...</span>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    @* Footer count *@
    <div class="px-5 py-3 border-t border-border bg-surface flex items-center justify-between">
        <span id="dbCount" class="text-xs text-text-muted">--</span>
        <span class="text-xs text-text-muted">ARS Portal &middot; Databases</span>
    </div>
</div>

@* ══════════════ ADD DATABASE MODAL ══════════════ *@
<div id="dbModal"
     class="fixed inset-0 z-50 bg-black/40 backdrop-blur-sm items-center justify-center px-4">
    <div id="modalBox"
         class="bg-surface-card border border-border rounded-2xl shadow-xl w-full max-w-lg max-h-[90vh] overflow-y-auto">

        @* Modal header *@
        <div class="flex items-center justify-between px-6 py-4 border-b border-border sticky top-0 bg-surface-card z-10">
            <h2 class="text-text-primary font-semibold text-base">Add Database Configuration</h2>
            <button onclick="closeAddModal()"
                    class="w-7 h-7 flex items-center justify-center rounded-lg
                           text-text-muted hover:text-text-primary hover:bg-surface transition-colors">
                <svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" class="w-4 h-4">
                    <path d="M18 6 6 18M6 6l12 12"/>
                </svg>
            </button>
        </div>

        @* Modal body *@
        <div class="px-6 py-5 space-y-4">
            <div id="modalAlert" class="hidden"></div>

            <div>
                <label class="text-xs font-medium text-text-secondary block mb-1">Database Type <span class="text-red-500">*</span></label>
                <select id="newDbType"
                        class="w-full px-3 py-2.5 bg-surface border border-border rounded-xl text-sm
                               text-text-primary focus:outline-none focus:border-blue-400
                               focus:ring-2 focus:ring-blue-100 transition-colors">
                    <option value="PostgreSQL">PostgreSQL</option>
                    <option value="Oracle">Oracle</option>
                </select>
            </div>

            <div>
                <label class="text-xs font-medium text-text-secondary block mb-1">Host / IP Address <span class="text-red-500">*</span></label>
                <input id="newDbHost" type="text" placeholder="localhost or 192.168.1.100"
                       class="w-full px-3 py-2.5 bg-surface border border-border rounded-xl text-sm
                              text-text-primary placeholder-text-muted focus:outline-none
                              focus:border-blue-400 focus:ring-2 focus:ring-blue-100 transition-colors" />
            </div>

            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="text-xs font-medium text-text-secondary block mb-1">Port <span class="text-red-500">*</span></label>
                    <input id="newDbPort" type="number" placeholder="5432"
                           class="w-full px-3 py-2.5 bg-surface border border-border rounded-xl text-sm
                                  text-text-primary placeholder-text-muted focus:outline-none
                                  focus:border-blue-400 focus:ring-2 focus:ring-blue-100 transition-colors" />
                </div>
                <div>
                    <label class="text-xs font-medium text-text-secondary block mb-1">Database Name <span class="text-red-500">*</span></label>
                    <input id="newDbName" type="text" placeholder="my_database"
                           class="w-full px-3 py-2.5 bg-surface border border-border rounded-xl text-sm
                                  text-text-primary placeholder-text-muted focus:outline-none
                                  focus:border-blue-400 focus:ring-2 focus:ring-blue-100 transition-colors" />
                </div>
            </div>

            <div>
                <label class="text-xs font-medium text-text-secondary block mb-1">Username <span class="text-red-500">*</span></label>
                <input id="newDbUsername" type="text" placeholder="db_user"
                       class="w-full px-3 py-2.5 bg-surface border border-border rounded-xl text-sm
                              text-text-primary placeholder-text-muted focus:outline-none
                              focus:border-blue-400 focus:ring-2 focus:ring-blue-100 transition-colors" />
            </div>

            <div>
                <label class="text-xs font-medium text-text-secondary block mb-1">Password <span class="text-red-500">*</span></label>
                <input id="newDbPassword" type="password" placeholder="Enter database password"
                       class="w-full px-3 py-2.5 bg-surface border border-border rounded-xl text-sm
                              text-text-primary placeholder-text-muted focus:outline-none
                              focus:border-blue-400 focus:ring-2 focus:ring-blue-100 transition-colors" />
                <p class="text-xs text-text-muted mt-1">Password is used only to build the encrypted connection string and is never stored.</p>
            </div>

            @* Test connection result area *@
            <div id="testResultArea" class="hidden rounded-xl px-4 py-3 text-sm"></div>
        </div>

        @* Modal footer *@
        <div class="px-6 py-4 border-t border-border flex justify-between gap-3 sticky bottom-0 bg-surface-card">
            <button id="testConnectionBtn" onclick="testConnectionFromModal()"
                    class="px-4 py-2 text-sm text-blue-600 hover:text-blue-700
                           border border-blue-200 hover:border-blue-300 rounded-xl transition-colors flex items-center gap-2">
                <svg id="testBtnSpinner" class="hidden w-4 h-4 spinner" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
                </svg>
                <span id="testBtnText">Test Connection</span>
            </button>
            <div class="flex gap-3">
                <button onclick="closeAddModal()"
                        class="px-4 py-2 text-sm text-text-secondary hover:text-text-primary
                               border border-border rounded-xl transition-colors">
                    Cancel
                </button>
                <button id="saveDbBtn" onclick="saveDbConfig()"
                        class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white
                               text-sm font-medium rounded-xl transition-colors flex items-center gap-2">
                    <span id="saveBtnText">Save Configuration</span>
                    <svg id="saveBtnSpinner" class="hidden w-4 h-4 spinner" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</div>

