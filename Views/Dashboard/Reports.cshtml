function collectDestinations(prefix) {
    const destinations = [];
    document.querySelectorAll(`#${prefix}DestinationsList .destination-card`).forEach(card => {
        const type = card.querySelector('select').value;
        const dest = { destinationType: type, isActive: true };
        
        if (type === 'email') {
