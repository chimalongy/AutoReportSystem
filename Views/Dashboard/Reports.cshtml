    // Email chip input handling
    function handleEmailChip(event, inputId, chipsId, hiddenId) {
        if (event.key === 'Enter' || event.key === ',') {
            event.preventDefault();
            const input = document.getElementById(inputId);
            const email = input.value.trim().replace(/,$/, '');
            if (email && isValidEmail(email)) {
                addEmailChip(email, chipsId, hiddenId);
                input.value = '';
            }
        } else if (event.key === 'Backspace' && !event.target.value) {
            const chips = document.getElementById(chipsId);
            const lastChip = chips.lastElementChild;
            if (lastChip) lastChip.remove();
            updateHiddenEmails(chipsId, hiddenId);
        }
    }

    function isValidEmail(email) {
        return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email);
    }

    function addEmailChip(email, chipsId, hiddenId) {
        const chips = document.getElementById(chipsId);
        const existing = Array.from(chips.children).map(c => c.dataset.email);
        if (existing.includes(email)) return;
        
        const chip = document.createElement('span');
        chip.className = 'email-chip';
        chip.dataset.email = email;
        chip.innerHTML = `${escHtml(email)} <button onclick="removeEmailChip(this, '${chipsId}', '${hiddenId}')" type="button">&times;</button>`;
        chips.appendChild(chip);
        updateHiddenEmails(chipsId, hiddenId);
    }

    function removeEmailChip(btn, chipsId, hiddenId) {
        btn.parentElement.remove();
        updateHiddenEmails(chipsId, hiddenId);
    }

    function updateHiddenEmails(chipsId, hiddenId) {
        const chips = document.getElementById(chipsId);
        const emails = Array.from(chips.children).map(c => c.dataset.email);
        document.getElementById(hiddenId).value = emails.join(',');
    }

