                payload.scheduleTime = document.getElementById('editMonthlyTime').value;
            }
            if (editCurrentFrequency === 'custom_dates') {
                if (editCustomDates.length === 0) { showEditModalAlert('Please select at least one date.', 'error'); return; }
                payload.scheduleCustomDates = editCustomDates.map(d => formatDateInput(d));
            }
            if (editCurrentFrequency === 'custom_recurring') {
                const recs = [];
                document.querySelectorAll('#editCustomRecurringList .custom-recurring-row').forEach(row => {
                    const date = row.querySelector('.edit-custom-rec-date').value;
                    const time = row.querySelector('.edit-custom-rec-time').value;
                    if (date && time) recs.push({ date, time });
                });
                if (recs.length === 0) { showEditModalAlert('Please add at least one date and time.', 'error'); return; }
                payload.scheduleCustomRecurring = recs;
            }
        }

        // ── Distribution config ──
        payload.enableEmailDistribution = document.getElementById('editEnableEmailDist').value === 'true';
        if (payload.enableEmailDistribution) {
            payload.emailToRecipients = document.getElementById('editToRecipients').value || null;
            payload.emailCcRecipients = document.getElementById('editCcRecipients').value || null;
            payload.emailBccRecipients = document.getElementById('editBccRecipients').value || null;
            payload.emailSubject = document.getElementById('editEmailSubject').value || null;
            payload.emailBodyTemplate = document.getElementById('editEmailBody').value || null;
        }
        payload.enableFileSave = document.getElementById('editEnableFileSave').value === 'true';
        if (payload.enableFileSave) {
            payload.fileSavePath = document.getElementById('editFileSavePath').value || null;
        }
        payload.distributionDestinations = collectDestinations('edit');

        const btn = document.getElementById('updateReportBtn');
        const spinner = document.getElementById('updateBtnSpinner');
        const btnText = document.getElementById('updateBtnText');
        btn.disabled = true;
        spinner.classList.remove('hidden');
        btnText.textContent = 'Updating...';

        try {
            const res = await fetch(`/Dashboard/Reports/Update/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.message || 'Failed to update report');

            const idx = allReports.findIndex(r => r.id === id);
            if (idx >= 0) allReports[idx] = data;
            renderTable(allReports);
            closeEditModal();
            showAlert('Report updated successfully.', 'success');
        } catch (err) {
            showEditModalAlert(err.message || 'Failed to update report. Please try again.', 'error');
        } finally {
            btn.disabled = false;
            spinner.classList.add('hidden');
            btnText.textContent = 'Update Report';
        }
    }

    // ══════════════════════════════════════════════════════════════════════
    // ALERT HELPERS
    // ══════════════════════════════════════════════════════════════════════

    function showAlert(message, type) {
        const el = document.getElementById('alertArea');
        const isSuccess = type === 'success';
        el.className = `mb-4 px-4 py-3 rounded-xl text-sm border flex items-center gap-2
            ${isSuccess
                ? 'bg-green-50 text-green-700 border-green-200'
                : 'bg-red-50 text-red-700 border-red-200'}`;
        el.innerHTML = `
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                ${isSuccess
                    ? '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>'
                    : '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>'}
            </svg>
            ${escHtml(message)}`;
        el.classList.remove('hidden');
        setTimeout(() => el.classList.add('hidden'), 4000);
    }

    function showModalAlert(message, type) {
        const el = document.getElementById('modalAlert');
        el.className = `mb-1 px-3 py-2 rounded-xl text-xs border
            ${type === 'error' ? 'bg-red-50 text-red-700 border-red-200' : 'bg-green-50 text-green-700 border-green-200'}`;
        el.textContent = message;
        el.classList.remove('hidden');
    }

    function showEditModalAlert(message, type) {
        const el = document.getElementById('editModalAlert');
        el.className = `mb-1 px-3 py-2 rounded-xl text-xs border
            ${type === 'error' ? 'bg-red-50 text-red-700 border-red-200' : 'bg-green-50 text-green-700 border-green-200'}`;
        el.textContent = message;
        el.classList.remove('hidden');
    }

    // ══════════════════════════════════════════════════════════════════════
    // EVENT LISTENERS & INIT
    // ══════════════════════════════════════════════════════════════════════

    document.getElementById('reportModal').addEventListener('click', function(e) {
        if (e.target === this) closeAddModal();
    });
    document.getElementById('editReportModal').addEventListener('click', function(e) {
        if (e.target === this) closeEditModal();
    });
    document.getElementById('confirmModal').addEventListener('click', function(e) {
        if (e.target === this) closeConfirm();
    });

    // Load on page ready
    loadData();
</script>

}