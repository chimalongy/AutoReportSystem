                    card.querySelector('.dest-to').value = dest.emailTo || '';
                    card.querySelector('.dest-cc').value = dest.emailCc || '';
                    card.querySelector('.dest-bcc').value = dest.emailBcc || '';
                    card.querySelector('.dest-subject').value = dest.emailSubject || '';
                    card.querySelector('.dest-body').value = dest.emailBody || '';
                } else {
                  card.querySelector('.dest-path').value = dest.filePath || '';
    card.querySelector('.dest-max-rows').value = dest.maxRowsPerSheet || '1048576';
                }
            });
        }

        document.getElementById('editModalAlert').classList.add('hidden');
        document.getElementById('editReportModal').classList.add('open');
    }

