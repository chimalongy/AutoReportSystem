            dest.emailCc = card.querySelector('.dest-cc')?.value || null;
            dest.emailBcc = card.querySelector('.dest-bcc')?.value || null;
            dest.emailSubject = card.querySelector('.dest-subject')?.value || null;
            dest.emailBody = card.querySelector('.dest-body')?.value || null;
        } else {
            dest.filePath = card.querySelector('.dest-path')?.value || null;
    
        }
        destinations.push(dest);
    });
    return destinations;
}

    // ══════════════════════════════════════════════════════════════════════
    // SAVE REPORT
    // ══════════════════════════════════════════════════════════════════════

    async function saveReport() {
        const name = document.getElementById('newReportName').value.trim();
        const dbConfigId = parseInt(document.getElementById('newDbConfig').value);
        const query = document.getElementById('newQuery').value.trim();
        const outputFileName = document.getElementById('newOutputFileName').value.trim();
        const outputFormat = document.getElementById('newOutputFormat').value;

        if (!name) { showModalAlert('Report name is required.', 'error'); return; }
        if (!dbConfigId) { showModalAlert('Please select a database.', 'error'); return; }
        if (!query) { showModalAlert('Report query is required.', 'error'); return; }
        if (!outputFileName) { showModalAlert('Output file name is required.', 'error'); return; }

        const payload = {
        name, 
        dbConnectionConfigId: dbConfigId, 
        query,
        outputFileName, 
        outputFormat,
        executionType: currentExecType,
        // ADD THIS:
        maxRowsPerSheet: parseInt(document.getElementById('newMaxRowsPerSheet').value) || null
    };

        // Automation config
        if (currentExecType === 'single') {
            const timing = document.querySelector('input[name="singleTiming"]:checked')?.value || 'immediately';
            payload.singleRunTiming = timing;
            if (timing === 'scheduled') {
                const dt = document.getElementById('newSingleRunDateTime').value;
                if (!dt) { showModalAlert('Please specify a date and time.', 'error'); return; }
                payload.singleRunDateTime = dt;
            }
        } else {
            payload.scheduleFrequency = currentFrequency;
            if (!currentFrequency) { showModalAlert('Please select a schedule frequency.', 'error'); return; }

            if (currentFrequency === 'daily') {
                payload.scheduleTime = document.getElementById('newDailyTime').value;
            }
            if (currentFrequency === 'weekly') {
                if (selectedDays.length === 0) { showModalAlert('Please select at least one day.', 'error'); return; }
                payload.scheduleDaysOfWeek = selectedDays;
                payload.scheduleTime = document.getElementById('newWeeklyTime').value;
            }
            if (currentFrequency === 'monthly') {
                payload.scheduleDayOfMonth = parseInt(document.getElementById('newMonthlyDay').value);
                payload.scheduleTime = document.getElementById('newMonthlyTime').value;
            }
            if (currentFrequency === 'custom_dates') {
                if (customDates.length === 0) { showModalAlert('Please select at least one date.', 'error'); return; }
                payload.scheduleCustomDates = customDates.map(d => formatDateInput(d));
            }
            if (currentFrequency === 'custom_recurring') {
                const recs = [];
                document.querySelectorAll('#customRecurringList .custom-recurring-row').forEach(row => {
                    const date = row.querySelector('.custom-rec-date').value;
                    const time = row.querySelector('.custom-rec-time').value;
                    if (date && time) recs.push({ date, time });
                });
                if (recs.length === 0) { showModalAlert('Please add at least one date and time.', 'error'); return; }
                payload.scheduleCustomRecurring = recs;
            }
        }

        // ── Distribution config ──
        payload.enableEmailDistribution = document.getElementById('newEnableEmailDist').value === 'true';
        if (payload.enableEmailDistribution) {
            payload.emailToRecipients = document.getElementById('newToRecipients').value || null;
            payload.emailCcRecipients = document.getElementById('newCcRecipients').value || null;
            payload.emailBccRecipients = document.getElementById('newBccRecipients').value || null;
            payload.emailSubject = document.getElementById('newEmailSubject').value || null;
            payload.emailBodyTemplate = document.getElementById('newEmailBody').value || null;
        }
        payload.enableFileSave = document.getElementById('newEnableFileSave').value === 'true';
        if (payload.enableFileSave) {
            payload.fileSavePath = document.getElementById('newFileSavePath').value || null;
        }
        payload.distributionDestinations = collectDestinations('new');

        const btn = document.getElementById('saveReportBtn');
        const spinner = document.getElementById('saveBtnSpinner');
        const btnText = document.getElementById('saveBtnText');
        btn.disabled = true;
        spinner.classList.remove('hidden');
        btnText.textContent = 'Creating...';

        try {
            const res = await fetch('/Dashboard/Reports/Create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.message || 'Failed to create report');

            allReports.unshift(data);
            renderTable(allReports);
            closeAddModal();
            showAlert(`Report "${name}" created successfully.`, 'success');
        } catch (err) {
            showModalAlert(err.message || 'Failed to create report. Please try again.', 'error');
        } finally {
            btn.disabled = false;
            spinner.classList.add('hidden');
            btnText.textContent = 'Create Report';
        }
    }

