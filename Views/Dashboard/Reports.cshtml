                    <button type="button" onclick="addDestination('edit')"
                            class="add-dest-btn mt-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path d="M12 5v14M5 12h14"/>
                        </svg>
                        Add Delivery Destination
                    </button>
                </div>
            </div>
        </div>

       
        
        
        <div class="px-6 py-4 border-t border-border flex justify-end gap-3 sticky bottom-0 bg-surface-card rounded-b-2xl z-10">
            <button onclick="closeEditModal()"
                    class="px-4 py-2 text-sm text-text-secondary hover:text-text-primary
                           border border-border rounded-xl transition-colors">
                Cancel
            </button>
            <button id="updateReportBtn" onclick="updateReport()"
                    class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white
                           text-sm font-medium rounded-xl transition-colors flex items-center gap-2">
                <span id="updateBtnText">Update Report</span>
                <svg id="updateBtnSpinner" class="hidden w-4 h-4 spinner" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
                </svg>
            </button>
        </div>
    </div>
</div>

@* ============== CONFIRM MODAL ============== *@
<div id="confirmModal"
     class="fixed inset-0 z-50 bg-black/40 backdrop-blur-sm items-center justify-center px-4">
    <div id="confirmBox"
         class="bg-surface-card border border-border rounded-2xl shadow-xl w-full max-w-sm px-6 py-6">
        <div id="confirmIcon" class="w-10 h-10 rounded-full flex items-center justify-center mx-auto mb-4"></div>
        <h3 id="confirmTitle" class="text-text-primary font-semibold text-base text-center mb-1"></h3>
        <p id="confirmMessage" class="text-text-muted text-sm text-center mb-5"></p>
        <div class="flex gap-3">
            <button onclick="closeConfirm()"
                    class="flex-1 py-2 text-sm text-text-secondary border border-border rounded-xl hover:bg-surface transition-colors">
                Cancel
            </button>
            <button id="confirmActionBtn"
                    class="flex-1 py-2 text-sm font-medium text-white rounded-xl transition-colors">
                Confirm
            </button>
        </div>
    </div>
</div>
@section Scripts {

<script>
    let allReports = [];
    let allDatabases = [];
    let pendingAction = null;
    let currentExecType = 'single';
    let currentFrequency = '';
    let selectedDays = [];
    let customDates = [];
    let editCurrentExecType = 'single';
    let editCurrentFrequency = '';
    let editSelectedDays = [];
    let editCustomDates = [];

    // ══════════════════════════════════════════════════════════════════════
    // LOAD DATA
    // ══════════════════════════════════════════════════════════════════════

    async function loadData() {
        try {
            const [reportsRes, dbRes] = await Promise.all([
                fetch('/Dashboard/Reports/GetAll'),
                fetch('/Dashboard/Databases/GetAll')
            ]);
            if (!reportsRes.ok || !dbRes.ok) throw new Error('Failed to fetch');
            allReports = await reportsRes.json();
            allDatabases = await dbRes.json();
            populateDbDropdowns();
            renderTable(allReports);
        } catch (err) {
            document.getElementById('reportsTableBody').innerHTML = `
                <tr>
                    <td colspan="8" class="text-center py-12 text-text-muted text-xs">
                        Failed to load reports. Please refresh the page.
                    </td>
                </tr>`;
        }
    }

    function populateDbDropdowns() {
        const opts = allDatabases.map(d => `<option value="${d.id}">${escHtml(d.databaseName)} (${escHtml(d.databaseType)}) — ${escHtml(d.host)}</option>`).join('');
        document.getElementById('newDbConfig').innerHTML = `<option value="">Select a database...</option>` + opts;
        document.getElementById('editDbConfig').innerHTML = `<option value="">Select a database...</option>` + opts;
    }

    // ══════════════════════════════════════════════════════════════════════
    // RENDER TABLE
    // ══════════════════════════════════════════════════════════════════════

    function renderTable(reports) {
        const tbody = document.getElementById('reportsTableBody');
        const countEl = document.getElementById('reportCount');

        countEl.textContent = `${reports.length} report${reports.length !== 1 ? 's' : ''} total`;

        if (reports.length === 0) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="8" class="text-center py-12 text-text-muted text-xs">
                        No reports found. Add one to get started.
                    </td>
                </tr>`;
            return;
        }

        tbody.innerHTML = reports.map(r => {
            const db = allDatabases.find(d => d.id === r.dbConnectionConfigId);
            const dbLabel = db ? `${escHtml(db.databaseName)} (${escHtml(db.databaseType)})` : 'Unknown';
            const statusClass = r.status === 'active' ? 'badge-active'
                              : r.status === 'inactive' ? 'badge-inactive'
                              : r.status === 'running' ? 'badge-running'
                              : 'badge-error';
            const scheduleLabel = getScheduleLabel(r);
            const lastRun = r.lastRunDate ? new Date(r.lastRunDate).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) : 'Never';
            const nextRun = r.nextRunDate ? new Date(r.nextRunDate).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) : '—';
            
            // Distribution indicators
            const distIndicators = [];
            if (r.enableEmailDistribution) distIndicators.push('<span class="text-[10px] px-1.5 py-0.5 rounded bg-blue-50 text-blue-600 border border-blue-100" title="Email">Email</span>');
            if (r.enableFileSave) distIndicators.push('<span class="text-[10px] px-1.5 py-0.5 rounded bg-green-50 text-green-600 border border-green-100" title="File">File</span>');
            if (r.distributionDestinations?.length > 0) distIndicators.push(`<span class="text-[10px] px-1.5 py-0.5 rounded bg-purple-50 text-purple-600 border border-purple-100" title="Destinations">+${r.distributionDestinations.length}</span>`);
            const distHtml = distIndicators.length > 0 ? `<div class="flex gap-1 mt-1">${distIndicators.join('')}</div>` : '';

            return `
            <tr class="report-row border-b border-border last:border-0" id="row-${r.id}">
                <td class="px-5 py-3.5">
                    <div class="flex items-center gap-2.5">
                        <div class="w-7 h-7 rounded-md bg-blue-50 border border-blue-100 flex items-center justify-center flex-shrink-0">
                            <svg class="w-3.5 h-3.5 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/>
                                <line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
                            </svg>
                        </div>
                        <div>
                            <span class="text-text-primary font-medium">${escHtml(r.name)}</span>
                            ${distHtml}
                        </div>
                    </div>
                </td>
                <td class="px-5 py-3.5 text-text-secondary text-xs hidden md:table-cell">${dbLabel}</td>
                <td class="px-5 py-3.5 hidden sm:table-cell">
                    <span class="text-xs px-2 py-0.5 rounded-full border bg-surface text-text-muted border-border uppercase">
                        ${escHtml(r.outputFormat)}
                    </span>
                </td>
                <td class="px-5 py-3.5 text-text-muted text-xs hidden lg:table-cell">${scheduleLabel}</td>
                <td class="px-5 py-3.5">
                    <span class="text-xs px-2.5 py-0.5 rounded-full font-medium ${statusClass}">
                        ${escHtml(r.status || 'active')}
                    </span>
                </td>
                <td class="px-5 py-3.5 text-text-muted text-xs hidden lg:table-cell">${lastRun}</td>
                <td class="px-5 py-3.5 text-text-muted text-xs hidden lg:table-cell">${nextRun}</td>
                <td class="px-5 py-3.5 text-right">
                    <div class="flex items-center justify-end gap-1">
                        <a href="/Dashboard/Reports/${encodeURIComponent(r.name)}"
                           title="View report"
                           class="text-xs px-2.5 py-1.5 rounded-lg border border-border
                                  text-text-secondary hover:border-green-300 hover:text-green-600
                                  hover:bg-green-50 transition-colors">
                            View
                        </a>
                        <button onclick="openEditModal(${r.id})"
                                title="Edit report"
                                class="text-xs px-2.5 py-1.5 rounded-lg border border-border
                                       text-text-secondary hover:border-blue-300 hover:text-blue-600
                                       hover:bg-blue-50 transition-colors">
                            Edit
                        </button>
                        <button onclick="confirmToggleStatus(${r.id}, '${r.status === 'active' ? 'inactive' : 'active'}')"
                                title="${r.status === 'active' ? 'Deactivate' : 'Activate'}"
                                class="text-xs px-2.5 py-1.5 rounded-lg border transition-colors
                                    ${r.status === 'active'
                                        ? 'border-border text-text-secondary hover:border-amber-300 hover:text-amber-600 hover:bg-amber-50'
                                        : 'border-blue-200 text-blue-600 hover:bg-blue-50'}">
                            ${r.status === 'active' ? 'Deactivate' : 'Activate'}
                        </button>
                        <button onclick="confirmDelete(${r.id}, '${escHtml(r.name)}')"
                                title="Delete report"
                                class="text-xs px-2.5 py-1.5 rounded-lg border border-border
                                       text-text-secondary hover:border-red-300 hover:text-red-600
                                       hover:bg-red-50 transition-colors">
                            Delete
                        </button>
                    </div>
                </td>
            </tr>`;
        }).join('');
    }

    function getScheduleLabel(r) {
        if (r.executionType === 'single') {
            if (r.singleRunTiming === 'immediately') return 'Run Once (Immediate)';
            if (r.singleRunTiming === 'scheduled' && r.singleRunDateTime)
                return 'Run Once: ' + new Date(r.singleRunDateTime).toLocaleString('en-GB', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' });
            return 'Single Run';
        }
        if (r.executionType === 'scheduled') {
            const freq = r.scheduleFrequency;
            if (freq === 'daily') return 'Daily' + (r.scheduleTime ? ' at ' + r.scheduleTime.substring(0,5) : '');
            if (freq === 'weekly') return 'Weekly' + (r.scheduleDaysOfWeek ? ' (' + JSON.parse(r.scheduleDaysOfWeek).join(', ') + ')' : '');
            if (freq === 'monthly') return 'Monthly (Day ' + r.scheduleDayOfMonth + ')';
            if (freq === 'custom_dates') {
                const dates = r.scheduleCustomDates ? JSON.parse(r.scheduleCustomDates) : [];
                return dates.length + ' custom date' + (dates.length !== 1 ? 's' : '');
            }
            if (freq === 'custom_recurring') {
                const rec = r.scheduleCustomRecurring ? JSON.parse(r.scheduleCustomRecurring) : [];
                return rec.length + ' scheduled run' + (rec.length !== 1 ? 's' : '');
            }
            return 'Scheduled';
        }
        return '—';
    }

    // ══════════════════════════════════════════════════════════════════════
    // UTILITY HELPERS
    // ══════════════════════════════════════════════════════════════════════

    function escHtml(str) {
        return String(str)
            .replace(/&/g,'&amp;').replace(/</g,'&lt;')
            .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function formatDateInput(date) {
        const d = new Date(date);
        const year = d.getFullYear();
        const month = String(d.getMonth() + 1).padStart(2, '0');
        const day = String(d.getDate()).padStart(2, '0');
        return `${year}-${month}-${day}`;
    }

    function formatDateTimeLocal(dateStr) {
        const d = new Date(dateStr);
        const year = d.getFullYear();
        const month = String(d.getMonth() + 1).padStart(2, '0');
        const day = String(d.getDate()).padStart(2, '0');
        const hours = String(d.getHours()).padStart(2, '0');
        const minutes = String(d.getMinutes()).padStart(2, '0');
        return `${year}-${month}-${day}T${hours}:${minutes}`;
    }

    // ══════════════════════════════════════════════════════════════════════
    // CONFIRM MODAL
    // ══════════════════════════════════════════════════════════════════════

    function openConfirm({ icon, iconBg, title, message, btnColor, action }) {
        document.getElementById('confirmIcon').className =
            `w-10 h-10 rounded-full flex items-center justify-center mx-auto mb-4 ${iconBg}`;
        document.getElementById('confirmIcon').innerHTML = icon;
        document.getElementById('confirmTitle').textContent   = title;
        document.getElementById('confirmMessage').textContent = message;

        const btn = document.getElementById('confirmActionBtn');
        btn.className = `flex-1 py-2 text-sm font-medium text-white rounded-xl transition-colors ${btnColor}`;
        pendingAction = action;
        btn.onclick = () => { pendingAction(); };

        document.getElementById('confirmModal').classList.add('open');
    }

    function closeConfirm() {
        document.getElementById('confirmModal').classList.remove('open');
        pendingAction = null;
    }

    // ══════════════════════════════════════════════════════════════════════
    // DELETE
    // ══════════════════════════════════════════════════════════════════════

    function confirmDelete(reportId, name) {
        openConfirm({
            icon: `<svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                       <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                       <path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/>
                   </svg>`,
            iconBg:   'bg-red-50',
            title:    'Delete Report',
            message:  `Are you sure you want to permanently delete "${name}"? This action cannot be undone.`,
            btnColor: 'bg-red-500 hover:bg-red-600',
            action:   () => deleteReport(reportId)
        });
    }

    async function deleteReport(reportId) {
        closeConfirm();
        try {
            const res = await fetch(`/Dashboard/Reports/Delete/${reportId}`, { method: 'POST' });
            if (!res.ok) throw new Error();
            document.getElementById(`row-${reportId}`)?.remove();
            allReports = allReports.filter(r => r.id !== reportId);
            document.getElementById('reportCount').textContent =
                `${allReports.length} report${allReports.length !== 1 ? 's' : ''} total`;
            showAlert('Report deleted successfully.', 'success');
        } catch {
            showAlert('Failed to delete report. Please try again.', 'error');
        }
    }

    // ══════════════════════════════════════════════════════════════════════
    // TOGGLE STATUS
    // ══════════════════════════════════════════════════════════════════════

    function confirmToggleStatus(reportId, newStatus) {
        const actionLabel = newStatus === 'active' ? 'Activate' : 'Deactivate';
        const color = newStatus === 'active' ? 'bg-blue-500 hover:bg-blue-600' : 'bg-amber-500 hover:bg-amber-600';
        openConfirm({
            icon: `<svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                       <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                   </svg>`,
            iconBg:   'bg-blue-50',
            title:    `${actionLabel} Report`,
            message:  `Are you sure you want to ${actionLabel.toLowerCase()} this report?`,
            btnColor: color,
            action:   () => toggleStatus(reportId, newStatus)
        });
    }

    async function toggleStatus(reportId, newStatus) {
        closeConfirm();
        try {
            const res = await fetch(`/Dashboard/Reports/UpdateStatus/${reportId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: newStatus })
            });
            if (!res.ok) throw new Error();
            const report = allReports.find(r => r.id === reportId);
            if (report) report.status = newStatus;
            renderTable(allReports);
            showAlert(`Report ${newStatus === 'active' ? 'activated' : 'deactivated'} successfully.`, 'success');
        } catch {
            showAlert('Failed to update report status. Please try again.', 'error');
        }
    }

    // ══════════════════════════════════════════════════════════════════════
    // ADD REPORT MODAL
    // ══════════════════════════════════════════════════════════════════════

    function openAddModal() {
        resetAddModal();
        document.getElementById('modalAlert').classList.add('hidden');
        document.getElementById('reportModal').classList.add('open');
        document.getElementById('newReportName').focus();
    }

    function closeAddModal() {
        document.getElementById('reportModal').classList.remove('open');
    }

    function resetAddModal() {
        // Basic fields
        document.getElementById('newReportName').value = '';
        document.getElementById('newDbConfig').value = '';
        document.getElementById('newQuery').value = '';
        document.getElementById('newOutputFileName').value = '';
        document.getElementById('newOutputFormat').value = 'csv';
           document.getElementById('newMaxRowsPerSheet').value = '1048576';
        // Execution type
        setExecType('single');
        document.querySelector('input[name="singleTiming"][value="immediately"]').checked = true;
        document.getElementById('newSingleRunDateTime').value = '';
        document.getElementById('singleDateTimeWrap').classList.add('hidden');
        setFrequency('');
        selectedDays = [];
        customDates = [];
        updateDayButtons();
        updateCustomDatesChips();
        document.getElementById('newDailyTime').value = '09:00';
        document.getElementById('newWeeklyTime').value = '09:00';
        document.getElementById('newMonthlyDay').value = '1';
        document.getElementById('newMonthlyTime').value = '09:00';
        document.getElementById('customRecurringList').innerHTML = `
            <div class="custom-recurring-row">
                <input type="date" class="custom-rec-date px-3 py-2 bg-surface border border-border rounded-lg text-sm text-text-primary" />
                <input type="time" class="custom-rec-time px-3 py-2 bg-surface border border-border rounded-lg text-sm text-text-primary" value="09:00" />
                <button type="button" onclick="removeRecurringRow(this)"
                        class="w-8 h-8 flex items-center justify-center rounded-lg text-red-500 hover:bg-red-50 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M18 6 6 18M6 6l12 12"/>
                    </svg>
                </button>
            </div>`;

        // ── Reset Distribution ──
        document.getElementById('emailDistToggle').classList.remove('active');
        document.getElementById('newEnableEmailDist').value = 'false';
        document.getElementById('emailConfigSection').classList.add('hidden');
        ['newToChips','newCcChips','newBccChips'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.innerHTML = '';
        });
        ['newToRecipients','newCcRecipients','newBccRecipients'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.value = '';
        });
        document.getElementById('newEmailSubject').value = '';
        document.getElementById('newEmailBody').value = '';

        document.getElementById('fileSaveToggle').classList.remove('active');
        document.getElementById('newEnableFileSave').value = 'false';
        document.getElementById('fileSaveConfigSection').classList.add('hidden');
        document.getElementById('newFileSavePath').value = '';

        document.getElementById('newDestinationsList').innerHTML = '';
    }

    // ══════════════════════════════════════════════════════════════════════
    // EDIT REPORT MODAL
    // ══════════════════════════════════════════════════════════════════════

    function openEditModal(reportId) {
        const report = allReports.find(r => r.id === reportId);
        if (!report) return;

        document.getElementById('editReportId').value = reportId;
        document.getElementById('editReportName').value = report.name || '';
        document.getElementById('editDbConfig').value = report.dbConnectionConfigId || '';
        document.getElementById('editQuery').value = report.query || '';
        document.getElementById('editOutputFileName').value = report.outputFileName || '';
        document.getElementById('editOutputFormat').value = report.outputFormat || 'csv';
         document.getElementById('editMaxRowsPerSheet').value = report.maxRowsPerSheet || '1048576';
        // Execution type
        setEditExecType(report.executionType || 'single');

        if (report.executionType === 'single') {
            const timing = report.singleRunTiming || 'immediately';
            const radio = document.querySelector(`input[name="editSingleTiming"][value="${timing}"]`);
            if (radio) radio.checked = true;
            if (timing === 'scheduled' && report.singleRunDateTime) {
                document.getElementById('editSingleRunDateTime').value = formatDateTimeLocal(report.singleRunDateTime);
                document.getElementById('editSingleDateTimeWrap').classList.remove('hidden');
            } else {
                document.getElementById('editSingleDateTimeWrap').classList.add('hidden');
            }
        } else if (report.executionType === 'scheduled') {
            const freq = report.scheduleFrequency || '';
            setEditFrequency(freq);
            if (freq === 'daily' && report.scheduleTime) {
                document.getElementById('editDailyTime').value = report.scheduleTime.substring(0,5);
            }
            if (freq === 'weekly') {
                editSelectedDays = report.scheduleDaysOfWeek ? JSON.parse(report.scheduleDaysOfWeek) : [];
                updateEditDayButtons();
                if (report.scheduleTime) document.getElementById('editWeeklyTime').value = report.scheduleTime.substring(0,5);
            }
            if (freq === 'monthly') {
                document.getElementById('editMonthlyDay').value = report.scheduleDayOfMonth || '1';
                if (report.scheduleTime) document.getElementById('editMonthlyTime').value = report.scheduleTime.substring(0,5);
            }
            if (freq === 'custom_dates') {
                editCustomDates = report.scheduleCustomDates ? JSON.parse(report.scheduleCustomDates) : [];
                updateEditCustomDatesChips();
            }
            if (freq === 'custom_recurring') {
                const rec = report.scheduleCustomRecurring ? JSON.parse(report.scheduleCustomRecurring) : [];
                const list = document.getElementById('editCustomRecurringList');
                list.innerHTML = rec.length > 0 ? rec.map(item => `
                    <div class="custom-recurring-row">
                        <input type="date" class="edit-custom-rec-date px-3 py-2 bg-surface border border-border rounded-lg text-sm text-text-primary" value="${formatDateInput(item.date)}" />
                        <input type="time" class="edit-custom-rec-time px-3 py-2 bg-surface border border-border rounded-lg text-sm text-text-primary" value="${item.time.substring(0,5)}" />
                        <button type="button" onclick="removeEditRecurringRow(this)"
                                class="w-8 h-8 flex items-center justify-center rounded-lg text-red-500 hover:bg-red-50 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M18 6 6 18M6 6l12 12"/>
                            </svg>
                        </button>
                    </div>`).join('') : `
                    <div class="custom-recurring-row">
                        <input type="date" class="edit-custom-rec-date px-3 py-2 bg-surface border border-border rounded-lg text-sm text-text-primary" />
                        <input type="time" class="edit-custom-rec-time px-3 py-2 bg-surface border border-border rounded-lg text-sm text-text-primary" value="09:00" />
                        <button type="button" onclick="removeEditRecurringRow(this)"
                                class="w-8 h-8 flex items-center justify-center rounded-lg text-red-500 hover:bg-red-50 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M18 6 6 18M6 6l12 12"/>
                            </svg>
                        </button>
                    </div>`;
            }
        }

        // ── Load Distribution Data ──
        if (report.enableEmailDistribution) {
            document.getElementById('editEmailDistToggle').classList.add('active');
            document.getElementById('editEnableEmailDist').value = 'true';
            document.getElementById('editEmailConfigSection').classList.remove('hidden');
            
            if (report.emailToRecipients) {
                report.emailToRecipients.split(',').forEach(e => {
                    if (e.trim()) addEmailChip(e.trim(), 'editToChips', 'editToRecipients');
                });
            }
            if (report.emailCcRecipients) {
                report.emailCcRecipients.split(',').forEach(e => {
                    if (e.trim()) addEmailChip(e.trim(), 'editCcChips', 'editCcRecipients');
                });
            }
            if (report.emailBccRecipients) {
                report.emailBccRecipients.split(',').forEach(e => {
                    if (e.trim()) addEmailChip(e.trim(), 'editBccChips', 'editBccRecipients');
                });
            }
            document.getElementById('editEmailSubject').value = report.emailSubject || '';
            document.getElementById('editEmailBody').value = report.emailBodyTemplate || '';
        } else {
            document.getElementById('editEmailDistToggle').classList.remove('active');
            document.getElementById('editEnableEmailDist').value = 'false';
            document.getElementById('editEmailConfigSection').classList.add('hidden');
            ['editToChips','editCcChips','editBccChips'].forEach(id => {
                const el = document.getElementById(id);
                if (el) el.innerHTML = '';
            });
