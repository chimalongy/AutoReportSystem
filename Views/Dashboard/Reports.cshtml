            document.getElementById('editEnableFileSave').value = 'false';
            document.getElementById('editFileSaveConfigSection').classList.add('hidden');
            document.getElementById('editFileSavePath').value = '';
        }

        // Load destinations
        const destList = document.getElementById('editDestinationsList');
        destList.innerHTML = '';
        if (report.distributionDestinations && report.distributionDestinations.length > 0) {
            report.distributionDestinations.forEach(dest => {
                addDestination('edit');
                const cards = destList.querySelectorAll('.destination-card');
                const card = cards[cards.length - 1];
                card.querySelector('select').value = dest.destinationType;
